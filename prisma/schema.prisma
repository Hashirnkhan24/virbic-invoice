generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Clerk user mapping (synced via webhooks)
model User {
  id            String    @id @default(cuid())
  clerkId       String    @unique // Clerk user ID
  email         String    @unique
  name          String?
  avatar        String?
  phone         String?   // WhatsApp bot interaction phone
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Notification preferences
  emailInvoiceSent        Boolean  @default(true)
  emailPaymentReceived    Boolean  @default(true)
  emailInvoiceOverdue     Boolean  @default(true)
  emailWeeklySummary      Boolean  @default(true)
  reminderOverdueEnabled  Boolean  @default(true)
  reminderFrequencyDays   Int      @default(3)
  reminderMaxCount        Int      @default(3)
  reminderSubjectTemplate String   @default("Reminder: Invoice {number} for {amount} is overdue")
  reminderBodyTemplate    String?  @db.Text

  // Relations
  businesses    Business[]
  clients       Client[]
  invoices      Invoice[]
  items         Item[]
  subscriptions Subscription?
  preferences   UserPreference?
}

model Business {
  id              String   @id @default(cuid())
  userId          String
  name            String
  gstin           String?  // 15 character GSTIN
  pan             String?  // 10 character PAN
  address         String?
  city            String?
  state           String?  // State code for GST (e.g., "27" for Maharashtra)
  pincode         String?
  phone           String?
  email           String?
  bankName        String?
  accountNumber   String?
  ifscCode        String?
  upiId           String?
  logo            String?  // URL to uploaded logo
  signature       String?  // URL to uploaded signature
  brandColor      String   @default("#10b981") // Hex color
  invoicePrefix   String   @default("INV")
  invoiceNumber   Int      @default(1) // Next invoice number
  financialYear   String   // e.g., "2026-27"
  isDefault       Boolean  @default(false)
  // Defaults & Branding
  defaultTemplate       String   @default("modern")
  defaultTerms          String?  @db.Text
  defaultNotes          String?  @db.Text
  defaultDueDateDays    Int      @default(30)
  defaultGstRate        Decimal  @default(18.00) @db.Decimal(5, 2)
  defaultPlaceOfSupply  String?
  currency              String   @default("INR")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  user            User     @relation(fields: [userId], references: [id])
  invoices        Invoice[]
  
  @@index([userId])
}

model Client {
  id              String    @id @default(cuid())
  userId          String
  businessId      String?
  name            String
  gstin           String?   // Client GSTIN
  email           String?
  phone           String?
  billingAddress  String?
  billingCity     String?
  billingState    String?   // State code
  billingPincode  String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingPincode String?
  notes           String?
  
  // Lightweight counters for quick display
  totalBilled      Decimal  @default(0.00) @db.Decimal(12, 2)  // Sum of PAID invoices
  totalOutstanding Decimal  @default(0.00) @db.Decimal(12, 2)  // Sum of SENT + OVERDUE + PARTIAL
  invoiceCount     Int      @default(0)                        // Total invoices created
  lastInvoiceDate  DateTime?                                    // Most recent invoice issueDate
  
  // Soft delete for client with invoice history
  isDeleted        Boolean  @default(false)
  deletedAt        DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user                  User                  @relation(fields: [userId], references: [id])
  invoices              Invoice[]
  reminderLogs          ReminderLog[]
  portal                ClientPortal?
  whatsAppConversations WhatsAppConversation[]

  
  @@index([userId])
}

model Item {
  id          String   @id @default(cuid())
  userId      String
  businessId  String?
  name        String
  description String?
  hsnCode     String?  // HSN/SAC code
  rate        Decimal  @db.Decimal(10, 2)
  gstRate     Decimal  @default(18.00) @db.Decimal(5, 2) // Default 18%
  unit        String   @default("PCS") // PCS, HRS, etc.
  isService   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user        User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id                String   @id @default(cuid())
  invoiceNumber     String   // Formatted: INV/2026-27/001
  userId            String
  businessId        String
  clientId          String
  
  // Invoice settings
  template          String   @default("modern") // modern, minimal, professional, creative, dark
  currency          String   @default("INR")
  exchangeRate      Decimal  @default(1.00) @db.Decimal(10, 4) // For multi-currency
  
  // Dates
  issueDate         DateTime @default(now())
  dueDate           DateTime
  
  // GST & Tax
  placeOfSupply     String   // State code
  isInterState      Boolean  @default(false) // true = IGST, false = CGST+SGST
  reverseCharge     Boolean  @default(false)
  
  overallDiscount     Decimal  @default(0.00) @db.Decimal(12, 2)
  overallDiscountType String   @default("PERCENTAGE")
  cessRate            Decimal  @default(0.00) @db.Decimal(5, 2)
  
  // Totals (stored for performance)
  subTotal          Decimal  @db.Decimal(12, 2)
  discountTotal     Decimal  @default(0.00) @db.Decimal(12, 2)
  taxableAmount     Decimal  @db.Decimal(12, 2)
  cgstTotal         Decimal  @default(0.00) @db.Decimal(12, 2)
  sgstTotal         Decimal  @default(0.00) @db.Decimal(12, 2)
  igstTotal         Decimal  @default(0.00) @db.Decimal(12, 2)
  cessTotal         Decimal  @default(0.00) @db.Decimal(12, 2)
  roundOff          Decimal  @default(0.00) @db.Decimal(12, 2)
  grandTotal        Decimal  @db.Decimal(12, 2)
  
  // Additional
  notes             String?  @db.Text
  terms             String?  @db.Text
  customFields      Json?    // [{key: "PO Number", value: "PO-123"}]
  
  // Status
  status            InvoiceStatus @default(DRAFT)
  
  // Delivery
  pdfUrl            String?
  publicShareId     String?  @unique // For public link sharing
  sharePassword     String?  // Optional password for public link
  viewCount         Int      @default(0)
  
  // Payment tracking
  amountPaid        Decimal  @default(0.00) @db.Decimal(12, 2)
  paidAt            DateTime?
  paymentNotes      String?
  
  // Recurring
  isRecurring         Boolean  @default(false)
  isRecurringTemplate Boolean  @default(false)
  recurringFrequency   String?  // WEEKLY, MONTHLY, QUARTERLY, YEARLY
  recurringEndDate    DateTime?
  recurringStartDate  DateTime?
  parentInvoiceId     String?  // For invoices generated from a recurring template
  templateName        String?
  recurringStatus     String   @default("ACTIVE") // ACTIVE, PAUSED, EXPIRED
  nextDueDate         DateTime?
  
  // Reminders
  lastReminderAt    DateTime?
  reminderCount     Int      @default(0)
  reminders         InvoiceReminder[]
  reminderLogs      ReminderLog[]
  
  // Razorpay payment link tracking
  razorpayPaymentLinkId     String?   @unique
  razorpayPaymentLinkUrl    String?
  razorpayPaymentLinkStatus String?   @default("created")
  
  // UPI payment tracking
  upiPaymentLink            String?
  upiQrGeneratedAt          DateTime?
  paymentProofs             PaymentProof[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Relations
  user              User      @relation(fields: [userId], references: [id])
  business          Business  @relation(fields: [businessId], references: [id])
  client            Client    @relation(fields: [clientId], references: [id])
  lineItems         InvoiceLineItem[]
  payments          Payment[]
  shareLog          InvoiceShareLog?
  
  @@index([userId])
  @@index([businessId])
  @@index([clientId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  itemId      String? // Reference to saved item (optional)
  
  // Line item details
  description String
  hsnCode     String?
  quantity    Decimal @db.Decimal(10, 2)
  unit        String  @default("PCS")
  rate        Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0.00) @db.Decimal(10, 2) // Percentage or amount
  discountType String @default("PERCENTAGE") // PERCENTAGE or AMOUNT
  
  // Tax
  gstRate     Decimal @default(18.00) @db.Decimal(5, 2)
  cgstAmount  Decimal @default(0.00) @db.Decimal(10, 2)
  sgstAmount  Decimal @default(0.00) @db.Decimal(10, 2)
  igstAmount  Decimal @default(0.00) @db.Decimal(10, 2)
  
  // Calculated
  taxableValue Decimal @db.Decimal(10, 2)
  totalAmount  Decimal @db.Decimal(10, 2)
  
  // Relations
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  plan          Plan     @default(FREE)
  status        SubscriptionStatus @default(ACTIVE)
  
  // Usage tracking
  invoicesUsed  Int      @default(0)
  invoicesLimit Int      @default(5) // 5 for free, 15 for starter, -1 for unlimited
  
  // Razorpay
  razorpaySubscriptionId String?
  razorpayCustomerId     String?
  
  // Billing period
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User     @relation(fields: [userId], references: [id])
}

enum Plan {
  FREE
  STARTER
  PRO
  PRO_YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
}

model InvoiceReminder {
  id          String   @id @default(cuid())
  invoiceId   String
  sentAt      DateTime @default(now())
  subject     String
  body        String   @db.Text
  recipient   String
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  @@index([invoiceId])
}

// Client activity log (lightweight audit trail)
model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  action    String   // INVOICE_CREATED, PAYMENT_RECEIVED, REMINDER_SENT, NOTE_ADDED
  details   String?  // Human-readable description
  amount    Decimal? @db.Decimal(12, 2) // If payment-related
  createdAt DateTime @default(now())
  
  @@index([clientId])
  @@index([userId])
}

// Client notes (ad-hoc notes per client)
model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([clientId])
  @@index([userId])
}

// NEW: Payment model — records individual payment transactions against an invoice
model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  userId      String        // Denormalized for security/ownership checks
  
  // Payment details
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(UPI)
  reference   String?       // UTR number, transaction ID, check number
  notes       String?       // "Advance payment", "Final settlement"
  
  // Status
  status      PaymentStatus @default(CONFIRMED)
  
  // Gateway tracking (for future auto-reconciliation)
  gatewayRef  String?       // Razorpay payment_id, etc.
  gatewayName String?       // "razorpay", "stripe", "manual"
  razorpayPaymentId String?
  razorpayOrderId   String?
  
  // Link payment to proof
  paymentProofId    String?   @unique
  paymentProof      PaymentProof? @relation(fields: [paymentProofId], references: [id])
  
  // Timestamps
  paidAt      DateTime      // When the payment was made (user-editable, default now)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relations
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
  @@index([userId])
  @@index([gatewayRef])
}

enum PaymentMethod {
  UPI
  NEFT
  IMPS
  RTGS
  CASH
  CHEQUE
  CARD
  OTHER
}

enum PaymentStatus {
  PENDING    // Recorded but not yet confirmed
  CONFIRMED  // Verified by user
  FAILED     // Bounced check, failed transfer
  REFUNDED   // Payment was refunded
}

// NEW: Reminder templates (user-configurable per escalation stage)
model ReminderTemplate {
  id             String   @id @default(cuid())
  userId         String
  
  stage          Int      // 1=Polite, 2=Standard, 3=Firm, 4=Final
  tone           String   // "polite", "standard", "firm", "final"
  
  subject        String
  body           String   @db.Text
  
  // Stage configuration
  daysAfterDue   Int      // Days after due date to send this reminder (0 = on due date)
  daysAfterLast  Int      // Minimum days since last reminder
  sendEmail      Boolean  @default(true)
  generateWaMsg  Boolean  @default(true) // Generate WhatsApp message version
  
  isDefault      Boolean  @default(false) // System default templates (user can override)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@unique([userId, stage]) // One template per stage per user
  @@index([userId])
}

// NEW: Reminder log (audit trail of sent reminders)
model ReminderLog {
  id          String   @id @default(cuid())
  invoiceId   String
  userId      String
  clientId    String
  
  stage       Int      // Which escalation stage was used
  templateId  String?  // Reference to template used
  
  channel     String   // "email", "whatsapp", "both"
  content     String   @db.Text // Actual content sent
  
  // If "viewed but not paid" triggered early escalation
  triggeredBy String?  // "schedule", "viewed_not_paid"
  
  createdAt   DateTime @default(now())
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@index([invoiceId])
  @@index([userId])
  @@index([clientId])
}

// User settings preferences for confirmation messages and receipts
model UserPreference {
  id                    String  @id @default(cuid())
  userId                String  @unique
  confirmationChannel   String  @default("both") // whatsapp, email, both
  autoConfirmation      Boolean @default(true)
  includeReceiptPdf     Boolean @default(true)
  
  // WhatsApp config (BYOC optional override)
  whatsAppEnabled       Boolean @default(false)
  whatsAppProvider      String  @default("meta")
  twilioAccountSid      String?
  twilioAuthToken       String?
  twilioWhatsAppNumber  String?
  metaAccessToken       String?
  metaPhoneNumberId     String?
  
  // Client Portal Defaults
  portalEnabledDefault       Boolean @default(true)
  portalAutoCreate           Boolean @default(true)
  portalPasswordDefault      String?
  portalUseBusinessBranding  Boolean @default(true)
  portalBrandColorDefault    String  @default("#10b981")
  portalTitleDefault         String?
  portalShowPaidDefault      Boolean @default(true)
  portalAllowPdfDefault      Boolean @default(true)
  portalAllowPaymentDefault  Boolean @default(true)
  portalShowHistoryDefault   Boolean @default(true)
  
  upiAutoApproveEnabled      Boolean @default(false)
  upiAutoApproveHours        Int     @default(72)
  
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NEW: Client Portal configuration
model ClientPortal {
  id          String   @id @default(cuid())
  clientId    String   @unique
  userId      String   // Denormalized for security
  
  slug        String   @unique // e.g., "rstech", "acme-corp" — URL-friendly
  password    String?  // Optional bcrypt-hashed password protection
  
  // Branding
  brandColor  String   @default("#10b981") // Falls back to business brandColor
  logoUrl     String?  // Falls back to business logo
  title       String?  // e.g., "RS Tech Client Portal" — falls back to "{businessName} Portal"
  
  // Features
  showPaidInvoices     Boolean @default(true)
  allowPdfDownload     Boolean @default(true)
  allowPayment         Boolean @default(true) // Requires Razorpay
  showPaymentHistory   Boolean @default(true)
  
  // Settings
  enabled     Boolean  @default(true)
  expiresAt   DateTime? // Optional portal expiry
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  @@index([slug])
  @@index([userId])
}

// NEW: PaymentProof — stores client-submitted payment evidence
model PaymentProof {
  id              String       @id @default(cuid())
  invoiceId       String
  userId          String       // Denormalized for security
  
  // Payment proof data
  utr             String?      // 12-digit UPI UTR number
  screenshotUrl   String?      // Relative path to uploaded file (e.g. /uploads/proofs/...)
  amountPaid      Decimal      @db.Decimal(12, 2)
  
  // Status
  status          ProofStatus  @default(PENDING)
  
  // Metadata
  submittedAt     DateTime     @default(now())
  verifiedAt      DateTime?
  verifiedBy      String?
  rejectionReason String?
  
  // Auto-approval tracking
  autoApproveAt   DateTime?
  autoApproved    Boolean      @default(false)
  
  // Relations
  invoice         Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment         Payment?
  
  @@index([invoiceId])
  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
}

// NEW: Notification model
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      String?  // JSON string
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  
  @@index([userId])
  @@index([read])
}

// NEW: Invoice share log (tracks views and engagement)
model InvoiceShareLog {
  id                String             @id @default(cuid())
  shareId           String             @unique // The publicShareId from Invoice
  invoiceId         String             @unique
  
  // View tracking
  viewCount         Int                @default(0)
  firstViewedAt     DateTime?
  lastViewedAt      DateTime?
  uniqueViewerCount Int                @default(0) // Based on hashed IP uniqueness
  
  // Payment correlation
  viewedBeforePayment Boolean          @default(false)
  viewsBeforePayment  Int                @default(0)
  
  // Device/browser analytics
  lastDeviceType    String?            // mobile, desktop, tablet
  lastBrowser       String?            // Chrome, Safari, etc.
  lastCountry       String?            // IN, US, etc.
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  invoice           Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  viewEvents        InvoiceViewEvent[]
  
  @@index([shareId])
  @@index([invoiceId])
}

// NEW: Individual view events (for detailed analytics)
model InvoiceViewEvent {
  id          String   @id @default(cuid())
  shareLogId  String
  
  viewedAt    DateTime @default(now())
  ipHash      String?  // Hashed IP
  deviceType  String?
  browser     String?
  country     String?
  referrer    String?  // E.g. WhatsApp, Email, Direct
  
  // Relations
  shareLog    InvoiceShareLog @relation(fields: [shareLogId], references: [id], onDelete: Cascade)
  
  @@index([shareLogId])
  @@index([viewedAt])
}

// NEW: WhatsApp conversation tracking per freelancer-client pair
model WhatsAppConversation {
  id              String   @id @default(cuid())
  userId          String   // The freelancer (BillCraft user)
  clientId        String   // The freelancer's client
  clientPhone     String   // Normalized E.164: +91XXXXXXXXXX
  
  // State management
  status          String   @default("ACTIVE") // ACTIVE, OPTED_OUT, BLOCKED
  lastMessageAt   DateTime?
  messageCount    Int      @default(0)
  
  // Opt-in compliance (WhatsApp mandatory)
  optInStatus     String   @default("PENDING") // PENDING, CONFIRMED, DECLINED
  optInAt         DateTime?
  optInMethod     String?  // "invoice_delivery", "manual", "qr_scan"
  
  // Context for AI conversations (stored as JSON, migrated to Redis in Phase 3)
  conversationContext Json? @default("{}")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages        WhatsAppMessage[]
  
  @@unique([userId, clientPhone])
  @@index([userId])
  @@index([clientPhone])
  @@index([optInStatus])
}

model WhatsAppMessage {
  id              String   @id @default(cuid())
  conversationId  String
  
  direction       String   // INBOUND (client→system), OUTBOUND (system→client)
  messageType     String   // TEXT, IMAGE, DOCUMENT, VOICE, TEMPLATE, INTERACTIVE
  content         String   @db.Text
  mediaUrl        String?
  
  // Provider tracking
  providerMessageId String?  // Twilio SID or Meta message ID
  deliveryStatus  String   @default("SENT") // SENT, DELIVERED, READ, FAILED
  
  // AI processing
  aiProcessed     Boolean  @default(false)
  aiIntent        String?  // Classified intent (filled by AI layer in Phase 2)
  aiConfidence    Float?
  
  // Raw payload for debugging
  rawPayload      String?  @db.Text
  
  createdAt       DateTime @default(now())
  
  conversation    WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
  @@index([createdAt])
  @@index([aiProcessed])
}

// NEW: System template registry for outbound messages
model WhatsAppTemplate {
  id          String   @id @default(cuid())
  userId      String?  // NULL = system template, otherwise user custom
  name        String   @unique // e.g., "invoice_delivered", "payment_reminder_stage_1"
  category    String   // UTILITY, MARKETING (WhatsApp categories)
  language    String   @default("en")
  content     String   @db.Text
  variables   String[] // ["clientName", "invoiceNumber", "amount", "dueDate"]
  
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([name])
}

// NEW: AI action log for training, debugging, audit
model AIActionLog {
  id              String   @id @default(cuid())
  userId          String?  // NULL for client-side actions
  clientId        String?  // For client-side actions
  
  rawInput        String   @db.Text
  inputType       String   @default("TEXT") // TEXT, VOICE
  language        String?  // Detected: en, hi, hinglish
  
  parsedIntent    String
  parsedEntities  Json
  confidence      Float
  missingFields   String[]
  
  actionTaken     String   // What the system did
  actionResult    Json?    // Success/failure details
  
  conversationTurn Int     @default(1)
  sessionId       String
  
  processingTimeMs Int      // Performance tracking
  
  error           String?
  createdAt       DateTime @default(now())
  
  @@index([userId])
  @@index([clientId])
  @@index([sessionId])
  @@index([createdAt])
}

// NEW: Pending confirmations (for confirmation loop state)
model PendingConfirmation {
  id              String   @id @default(cuid())
  sessionId       String   @unique
  
  actionType      String   // CREATE_INVOICE, MARK_PAID, etc.
  draftData       Json     // The proposed action data
  
  expiresAt       DateTime // 10 minutes from creation
  confirmedAt     DateTime?
  cancelledAt     DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([sessionId])
  @@index([expiresAt])
}



